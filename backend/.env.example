# Copy to .env for local dev. On Render, add these in Dashboard → Environment.

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Free key from https://pixabay.com/api/docs/  (20,000 requests/day free)
PIXABAY_API_KEY=your_key_from_pixabay_com

# ── OPTIONAL: adds more wallpaper sources (more variety, higher quality) ────
# Free key from https://unsplash.com/developers  (50 requests/hour free)
# UNSPLASH_ACCESS_KEY=your_key_from_unsplash_com

# Free key from https://www.pexels.com/api/  (200 requests/hour free)
# PEXELS_API_KEY=your_key_from_pexels_com

# Free key from https://aistudio.google.com/  (for AI wish generation)
# GEMINI_API_KEY=your_key_from_aistudio_google_com

# ── REQUIRED FOR GITHUB ACTIONS SYNC ────────────────────────────────────────
# Any random secret string — must match GitHub Actions secret "ADMIN_SECRET_KEY"
# e.g. run: openssl rand -hex 16   → copy the output here and into GitHub Secrets
# ADMIN_SECRET_KEY=your_random_secret_here

PORT=3000
