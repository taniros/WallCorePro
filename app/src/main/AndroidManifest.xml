<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.SET_WALLPAPER" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".WallCoreApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WallCorePro"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        tools:targetApi="31">

        <!-- Main Activity with splash screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.WallCorePro.SplashScreen"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="unspecified">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep-link intent filter — handles wallcorepro:// URIs from app shortcuts,
                 notifications, and shared wallpaper links. Routes to the correct in-app
                 destination via MainActivity.onNewIntent → NavController. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="wallcorepro" />
            </intent-filter>

            <!-- Static app shortcuts: 3 quick-access actions in the launcher long-press menu.
                 Shown on Android 7.1+ (API 25+). Drives daily re-engagement with zero cost. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- FileProvider for sharing wallpapers -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <!-- WorkManager Initializer (disable default, use Hilt) -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!--
            Firebase Performance throws a fatal IllegalArgumentException when the
            google-services.json contains placeholder values (YOUR_PROJECT_NUMBER etc.).
            Disable it completely until a real Firebase project is configured.
            Firebase Analytics and Crashlytics also emit errors with a placeholder config,
            so they are disabled here too. Remove these tags once you add your real
            google-services.json from the Firebase Console.
        -->
        <meta-data
            android:name="firebase_performance_collection_deactivated"
            android:value="true" />
        <meta-data
            android:name="firebase_analytics_collection_enabled"
            android:value="false" />
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="false" />

        <!-- Home screen widget — shows wallpaper thumbnail + wish greeting -->
        <receiver
            android:name=".widget.WallpaperWidget"
            android:exported="true"
            android:label="@string/widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/wallpaper_widget_info" />
        </receiver>

        <!-- Boot receiver: reschedules daily notifications after device restart -->
        <receiver
            android:name=".worker.BootReceiver"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <!-- AdMob App ID (test key - replace with real) -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />

        <!-- Resolve manifest merger conflict for AdServices -->
        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <!--
            16 KB memory page size — Android 15+ requirement.
            Declares that all native libraries bundled in this APK (Firebase, AdMob,
            OneSignal) have been compiled with PT_LOAD segments aligned to 16 KB.
            Without this property the OS refuses to load any .so in the process on
            devices running in 16 KB page-size mode, causing an immediate crash.

            The companion build.gradle.kts setting jniLibs { useLegacyPackaging = false }
            stores .so files uncompressed so the kernel can mmap them directly at
            16 KB-aligned offsets from the APK without extracting to a temp file.
        -->
        <property
            android:name="android.nativeSupportUpto16kPageSize"
            android:value="true" />

    </application>

</manifest>