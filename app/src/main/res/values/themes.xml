<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - NoActionBar for Compose -->
    <style name="Theme.WallCorePro" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen: deep moonlit background -->
    <style name="Theme.WallCorePro.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_warm</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.WallCorePro</item>
    </style>
</resources>